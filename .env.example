# Server
PORT=3001
JWT_SECRET=change-me-to-a-long-random-secret
DB_PATH=/app/data/cloudladder.db

# Host binding used by docker-compose.yml.
# Keep 127.0.0.1 when an Nginx reverse proxy is on the same server.
APP_BIND_HOST=127.0.0.1
APP_HOST_PORT=3101

# Third-party enterprise info API (choose one)
# Tianyancha: https://open.tianyancha.com/
# TIANYANCHA_API_KEY=your_tianyancha_api_key_here
# Qichacha: https://openapi.qichacha.com/
# QICHACHA_API_KEY=your_qichacha_api_key_here
